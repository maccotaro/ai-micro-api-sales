{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "LLMGenerateResponse",
  "description": "Expected response schema from api-llm POST /llm/generate. Consumer: api-sales.",
  "type": "object",
  "required": [
    "response",
    "model",
    "provider"
  ],
  "properties": {
    "response": {
      "type": "string",
      "description": "Generated text response"
    },
    "model": {
      "type": "string",
      "description": "Model name used for generation"
    },
    "total_tokens": {
      "type": ["integer", "null"],
      "description": "Total tokens consumed"
    },
    "provider": {
      "type": "string",
      "description": "LLM provider name (e.g., ollama)"
    },
    "thinking": {
      "type": ["string", "null"],
      "description": "Thinking/reasoning output if supported"
    }
  },
  "additionalProperties": true
}
